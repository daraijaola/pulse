# Copy to .env.local for Vite (VITE_ prefix required)
# Cluster: devnet | mainnet-beta
VITE_SOLANA_CLUSTER=devnet

# Base layer RPC
VITE_SOLANA_RPC=https://api.devnet.solana.com

# MagicBlock Magic Router (auto-routes base vs ER)
VITE_MAGIC_ROUTER_RPC=https://devnet-router.magicblock.app
VITE_MAGIC_ROUTER_WS=wss://devnet-router.magicblock.app

# Direct Ephemeral Rollup RPC (Asia devnet)
VITE_ER_RPC=https://devnet-as.magicblock.app
VITE_ER_WS=wss://devnet-as.magicblock.app

# ER validator identity (Asia)
VITE_ER_VALIDATOR=MAS1Dt9qreoRMQ14YQuhg8UTZMMzDdKhmkZMECCzk57

# Program id (fill after anchor deploy)
VITE_PULSE_PROGRAM_ID=

# Feature flags
VITE_USE_MOCK_CHAIN=true
